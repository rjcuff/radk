{
  "$schema": "https://mono-ui.dev/schema/registry-item.json",
  "name": "contact-form",
  "type": "registry:block",
  "title": "Contact Form",
  "description": "A contact form section with name, email, subject select, and message textarea.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "badge",
    "button",
    "card",
    "input",
    "label",
    "select",
    "textarea"
  ],
  "files": [
    {
      "path": "registry/radk/blocks/contact-form.tsx",
      "type": "registry:component",
      "content": "\"use client\"\n\nimport * as React from \"react\"\nimport { Badge } from \"@/registry/radk/ui/badge\"\nimport { Button } from \"@/registry/radk/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/radk/ui/card\"\nimport { Input } from \"@/registry/radk/ui/input\"\nimport { Label } from \"@/registry/radk/ui/label\"\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/registry/radk/ui/select\"\nimport { Textarea } from \"@/registry/radk/ui/textarea\"\n\nexport function ContactFormBlock() {\n  return (\n    <section className=\"py-20 px-6\">\n      <div className=\"mx-auto max-w-2xl space-y-10\">\n        <div className=\"text-center space-y-3\">\n          <Badge variant=\"outline\">Contact</Badge>\n          <h2 className=\"text-3xl font-black tracking-tight sm:text-4xl\">\n            Get in touch\n          </h2>\n          <p className=\"text-muted-foreground\">\n            We&apos;ll get back to you within 24 hours.\n          </p>\n        </div>\n        <Card>\n          <CardHeader>\n            <CardTitle>Send a message</CardTitle>\n            <CardDescription>\n              Fill out the form below and we&apos;ll be in touch.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"first-name\">First name</Label>\n                <Input id=\"first-name\" placeholder=\"Ryan\" />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"last-name\">Last name</Label>\n                <Input id=\"last-name\" placeholder=\"Cuff\" />\n              </div>\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"contact-email\">Email</Label>\n              <Input\n                id=\"contact-email\"\n                type=\"email\"\n                placeholder=\"ryan@example.com\"\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"subject\">Subject</Label>\n              <Select>\n                <SelectTrigger id=\"subject\">\n                  <SelectValue placeholder=\"Select a subject\" />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"general\">General inquiry</SelectItem>\n                  <SelectItem value=\"support\">Technical support</SelectItem>\n                  <SelectItem value=\"billing\">Billing</SelectItem>\n                  <SelectItem value=\"partnership\">Partnership</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"message\">Message</Label>\n              <Textarea\n                id=\"message\"\n                placeholder=\"Tell us how we can help...\"\n                rows={5}\n              />\n            </div>\n          </CardContent>\n          <CardFooter>\n            <Button className=\"w-full\">Send message</Button>\n          </CardFooter>\n        </Card>\n      </div>\n    </section>\n  )\n}\n"
    }
  ],
  "cssVars": {}
}
