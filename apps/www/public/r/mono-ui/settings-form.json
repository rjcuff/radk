{
  "$schema": "https://mono-ui.dev/schema/registry-item.json",
  "name": "settings-form",
  "type": "registry:block",
  "title": "Settings Form",
  "description": "An account settings page with profile fields, notification toggles, and security options.",
  "dependencies": [],
  "devDependencies": [],
  "registryDependencies": [
    "button",
    "card",
    "input",
    "label",
    "select",
    "separator",
    "switch"
  ],
  "files": [
    {
      "path": "registry/radk/blocks/settings-form.tsx",
      "type": "registry:component",
      "content": "\"use client\"\n\nimport * as React from \"react\"\nimport { Button } from \"@/registry/radk/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardHeader,\n  CardTitle,\n} from \"@/registry/radk/ui/card\"\nimport { Input } from \"@/registry/radk/ui/input\"\nimport { Label } from \"@/registry/radk/ui/label\"\nimport {\n  Select,\n  SelectContent,\n  SelectItem,\n  SelectTrigger,\n  SelectValue,\n} from \"@/registry/radk/ui/select\"\nimport { Separator } from \"@/registry/radk/ui/separator\"\nimport { Switch } from \"@/registry/radk/ui/switch\"\n\nexport function SettingsFormBlock() {\n  const [emailNotifications, setEmailNotifications] = React.useState(true)\n  const [marketingEmails, setMarketingEmails] = React.useState(false)\n  const [twoFactor, setTwoFactor] = React.useState(false)\n\n  return (\n    <section className=\"py-10 px-6\">\n      <div className=\"mx-auto max-w-2xl space-y-6\">\n        <div>\n          <h2 className=\"text-2xl font-black\">Settings</h2>\n          <p className=\"text-muted-foreground\">\n            Manage your account preferences.\n          </p>\n        </div>\n\n        <Card>\n          <CardHeader>\n            <CardTitle>Profile</CardTitle>\n            <CardDescription>Update your personal information.</CardDescription>\n          </CardHeader>\n          <CardContent className=\"space-y-4\">\n            <div className=\"grid grid-cols-2 gap-4\">\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"settings-first\">First name</Label>\n                <Input id=\"settings-first\" defaultValue=\"Ryan\" />\n              </div>\n              <div className=\"space-y-2\">\n                <Label htmlFor=\"settings-last\">Last name</Label>\n                <Input id=\"settings-last\" defaultValue=\"Cuff\" />\n              </div>\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"settings-email\">Email</Label>\n              <Input\n                id=\"settings-email\"\n                type=\"email\"\n                defaultValue=\"ryan@example.com\"\n              />\n            </div>\n            <div className=\"space-y-2\">\n              <Label htmlFor=\"settings-timezone\">Timezone</Label>\n              <Select defaultValue=\"et\">\n                <SelectTrigger id=\"settings-timezone\">\n                  <SelectValue />\n                </SelectTrigger>\n                <SelectContent>\n                  <SelectItem value=\"et\">Eastern Time (ET)</SelectItem>\n                  <SelectItem value=\"ct\">Central Time (CT)</SelectItem>\n                  <SelectItem value=\"pt\">Pacific Time (PT)</SelectItem>\n                  <SelectItem value=\"utc\">UTC</SelectItem>\n                </SelectContent>\n              </Select>\n            </div>\n            <Button>Save changes</Button>\n          </CardContent>\n        </Card>\n\n        <Card>\n          <CardHeader>\n            <CardTitle>Notifications</CardTitle>\n            <CardDescription>\n              Control how you receive notifications.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"space-y-4\">\n            <div className=\"flex items-center justify-between\">\n              <div>\n                <Label htmlFor=\"email-notifs\" className=\"font-bold\">\n                  Email notifications\n                </Label>\n                <p className=\"text-xs text-muted-foreground\">\n                  Receive emails about your account activity.\n                </p>\n              </div>\n              <Switch\n                id=\"email-notifs\"\n                checked={emailNotifications}\n                onCheckedChange={setEmailNotifications}\n              />\n            </div>\n            <Separator />\n            <div className=\"flex items-center justify-between\">\n              <div>\n                <Label htmlFor=\"marketing-emails\" className=\"font-bold\">\n                  Marketing emails\n                </Label>\n                <p className=\"text-xs text-muted-foreground\">\n                  Receive emails about new features and updates.\n                </p>\n              </div>\n              <Switch\n                id=\"marketing-emails\"\n                checked={marketingEmails}\n                onCheckedChange={setMarketingEmails}\n              />\n            </div>\n          </CardContent>\n        </Card>\n\n        <Card>\n          <CardHeader>\n            <CardTitle>Security</CardTitle>\n            <CardDescription>\n              Manage your account security settings.\n            </CardDescription>\n          </CardHeader>\n          <CardContent className=\"space-y-4\">\n            <div className=\"flex items-center justify-between\">\n              <div>\n                <Label htmlFor=\"two-factor\" className=\"font-bold\">\n                  Two-factor authentication\n                </Label>\n                <p className=\"text-xs text-muted-foreground\">\n                  Add an extra layer of security to your account.\n                </p>\n              </div>\n              <Switch\n                id=\"two-factor\"\n                checked={twoFactor}\n                onCheckedChange={setTwoFactor}\n              />\n            </div>\n            <Separator />\n            <div className=\"space-y-2\">\n              <Label>Password</Label>\n              <div>\n                <Button variant=\"outline\">Change password</Button>\n              </div>\n            </div>\n          </CardContent>\n        </Card>\n      </div>\n    </section>\n  )\n}\n"
    }
  ],
  "cssVars": {}
}

